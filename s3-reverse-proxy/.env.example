# =========================================================================
# LaunchPad S3 Reverse Proxy - Environment Configuration Example
# =========================================================================
# Copy this file to '.env' inside the s3-reverse-proxy directory

# Base path of the S3 bucket where build outputs are stored.
# In local development: http://localhost:4566/launchpad-assets (or localstack hostname)
# In production: https://your-bucket-name.s3.amazonaws.com
BASE_PATH=https://launchpad-assets.s3.amazonaws.com

# MongoDB connection URI (used to look up the deployment active on a custom domain/subdomain)
MONGODB_URI=mongodb://localhost:27017/launchpad
