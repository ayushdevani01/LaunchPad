# =========================================================================
# LaunchPad - Global Environment Configuration Example
# =========================================================================
# Copy this file to '.env' at the root of the project to configure services.
# These variables are read by 'docker-compose.yml' and passed to containers.

# -------------------------------------------------------------------------
# 1. DATABASE & REDIS CONFIGURATION
# -------------------------------------------------------------------------
# MongoDB connection URI. Inside docker-compose, 'mongodb' resolves to the container.
MONGODB_URI=mongodb://mongodb:27017/launchpad

# Redis connection URL. Inside docker-compose, 'redis' resolves to the container.
# Include the default password configured below.
REDIS_URL=redis://:redis_pass@redis:6379
REDIS_PASSWORD=redis_pass

# -------------------------------------------------------------------------
# 2. SECURITY & AUTHENTICATION
# -------------------------------------------------------------------------
# Secret used to sign JSON Web Tokens (JWT) for authentication
JWT_SECRET=super_secret_jwt_key_please_change_in_production

# GitHub OAuth App Credentials (Required for Github Login & Repositories selection)
# Create a Github OAuth Application in Github Developer Settings.
# Homepage URL: http://localhost:3000 (or your frontend domain)
# Authorization callback URL: http://localhost:9000/auth/github/callback (or your API domain/auth/github/callback)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:9000/auth/github/callback

# -------------------------------------------------------------------------
# 3. ROUTING & HOSTS
# -------------------------------------------------------------------------
# The URL where the Frontend (Next.js) is running
FRONTEND_URL=http://localhost:3000

# The URL of the reverse proxy that retrieves built static assets from S3.
# In development, it points to LocalStack S3 bucket path.
# In production, it should point to the real AWS S3 bucket base URL or the proxy itself.
BASE_PATH=http://localstack:4566/launchpad-assets

# Cloudflare API Token (Optional, only needed if Caddy is configured for automated HTTPS certificates using DNS-01 challenge)
CF_API_TOKEN=your_cloudflare_api_token_here

# -------------------------------------------------------------------------
# 4. AWS CONFIGURATION (For S3 assets and build deployment)
# -------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_BUCKET_NAME=launchpad-assets

# For local development with LocalStack, set mock credentials and the endpoint.
# In production on AWS, set real AWS credentials and leave AWS_ENDPOINT empty.
AWS_ACCESS_KEY_ID=mock
AWS_SECRET_ACCESS_KEY=mock
AWS_ENDPOINT=http://localstack:4566

# -------------------------------------------------------------------------
# 5. DOCKER & ECS BUILD MODE
# -------------------------------------------------------------------------
# MOCK_ECS=true runs the build server as a local docker container on the host.
# Since we are deploying on a single EC2 instance, we use MOCK_ECS=true.
MOCK_ECS=true

# Name of the docker network where api-server runs, so it can spawn build containers on the same network.
DOCKER_NETWORK=launchpad-network

# Internal callback URL for build containers to report status back to the api-server.
# In Docker Compose, the container can access the api-server using http://api-server:9000
INTERNAL_API_URL=http://api-server:9000

# Below are placeholder values for ECS mode (not used when MOCK_ECS=true)
AWS_ECS_CLUSTER=local
AWS_ECS_TASK_DEFINITION=mock-task
AWS_ECS_SUBNETS=mock-subnet
AWS_ECS_SECURITY_GROUPS=mock-sg
AWS_ECS_CONTAINER_NAME=build-server
