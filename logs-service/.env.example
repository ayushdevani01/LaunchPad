# =========================================================================
# LaunchPad Logs Service - Environment Configuration Example
# =========================================================================
# Copy this file to '.env' inside the logs-service directory

# Port for WebSocket connection
SOCKET_PORT=9002

# Redis connection URL (used for Pub/Sub of real-time build logs)
REDIS_URL=redis://localhost:6379

# MongoDB Connection URI (used to fetch deployment details for access validation)
MONGODB_URI=mongodb://localhost:27017/launchpad

# JWT Secret (must match the secret used in api-server to validate client connections)
JWT_SECRET=super_secret_jwt_key_please_change_in_production
