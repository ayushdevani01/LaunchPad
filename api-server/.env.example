# =========================================================================
# LaunchPad API Server - Environment Configuration Example
# =========================================================================
# Copy this file to '.env' inside the api-server directory (or set via system env)

# Port for the API server to run on
PORT=9000

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/launchpad

# Redis Connection URL
REDIS_URL=redis://localhost:6379

# Secret key for JWT signing/verification
JWT_SECRET=super_secret_jwt_key_please_change_in_production

# URL of the Next.js Frontend
FRONTEND_URL=http://localhost:3000

# GitHub OAuth credentials (required for login and repository listing)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:9000/auth/github/callback

# Google OAuth credentials (optional, disabled/not used in simplified setup)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_BUCKET_NAME=launchpad-assets
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS_ENDPOINT should be left empty for production (points to real S3).
# For local dev / LocalStack, set to: http://localhost:4566 (or http://localstack:4566 inside Docker)
AWS_ENDPOINT=

# Build server mode settings.
# MOCK_ECS=true runs build containers locally on the host using Docker instead of ECS.
# Set this to true for local development and for single EC2 deployments.
MOCK_ECS=true
DOCKER_NETWORK=launchpad-network
INTERNAL_API_URL=http://localhost:9000

# ECS configuration (only used if MOCK_ECS=false)
AWS_ECS_CLUSTER=launchpad-cluster
AWS_ECS_TASK_DEFINITION=launchpad-build-server
AWS_ECS_SUBNETS=subnet-xxxxxx,subnet-yyyyyy
AWS_ECS_SECURITY_GROUPS=sg-xxxxxx
AWS_ECS_CONTAINER_NAME=build-server
