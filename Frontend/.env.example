# =========================================================================
# LaunchPad Frontend - Environment Configuration Example
# =========================================================================
# Copy this file to '.env.local' inside the Frontend directory

# Public API URL pointing to the api-server (accessible by browser)
NEXT_PUBLIC_API_URL=http://localhost:9000

# Public Websocket URL pointing to the logs-service (accessible by browser)
NEXT_PUBLIC_LOGS_URL=ws://localhost:9002
