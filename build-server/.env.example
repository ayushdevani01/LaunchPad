# =========================================================================
# LaunchPad Build Server - Environment Configuration Example
# =========================================================================
# Note: These variables are set dynamically by the api-server when starting
# the build task, but are listed here for documentation and manual testing.

# URL of the git repository to clone
GIT_REPOSITORY__URL=https://github.com/user/repo.git

# GitHub personal access token (optional, used for cloning private repositories)
GITHUB_TOKEN=your_github_token

# ID of the project being deployed
CLIENT_PROJECT_ID=project_id_123

# ID of the deployment run
DEPLOYMENT_ID=deployment_id_456

# Redis URL for streaming build logs back to logs-service
REDIS_URL=redis://localhost:6379

# The root directory of the application code within the repository (optional, default is repository root)
SOURCE_DIR=

# Custom commands for installing dependencies and building the project (default is npm install && npm run build)
INSTALL_COMMAND=npm install
BUILD_COMMAND=npm run build
BUILD_OUTPUT_DIR=dist

# Git branch to clone (default: main)
BRANCH=main

# JSON string of key-value pairs representing custom user environment variables to inject into the build process
USER_ENV_VARS={"REACT_APP_API_URL":"https://api.example.com"}

# AWS credentials and bucket for uploading static build outputs to S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_BUCKET_NAME=launchpad-assets

# Endpoint URL for AWS client (optional, leave empty in production, set to e.g. http://localhost:4566 for local localstack)
AWS_ENDPOINT=

# API Callback URL (sent by api-server so build-server can notify it when build succeeds or fails)
API_CALLBACK_URL=http://localhost:9000/projects/project-slug/deployments/deployment-id/status
